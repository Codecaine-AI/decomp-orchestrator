{
  "name": "melee-decomp-orchestrator",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "orch": "bun src/bin/decomp-orchestrator.ts",
    "check": "tsc --noEmit",
    "smoke": "bun tests/smoke.ts",
    "regression-check": "bun src/bin/decomp-orchestrator.ts regression-check",
    "kg:sources": "bun src/bin/decomp-orchestrator.ts kg-sources",
    "kg:status": "bun src/bin/decomp-orchestrator.ts kg-status",
    "kg:import-agent-state": "bun src/bin/decomp-orchestrator.ts kg-import-agent-state",
    "kg:curate": "bun src/bin/decomp-orchestrator.ts kg-curate",
    "kg:maintain": "bun src/bin/decomp-orchestrator.ts kg-maintain",
    "kg:rebuild": "bun src/bin/decomp-orchestrator.ts kg-rebuild-graph",
    "kg:search": "bun src/bin/decomp-orchestrator.ts kg-search",
    "kg:smoke": "bun src/bin/decomp-orchestrator.ts kg-smoke",
    "kg:file-card": "bun src/bin/decomp-orchestrator.ts kg-file-card",
    "kg:rank-features": "bun src/bin/decomp-orchestrator.ts kg-rank-features",
    "kg:tool-indexes": "python3 knowledge/tools/build_tool_indexes.py",
    "pr:refresh": "python3 knowledge/sources/past_prs/commands/fetch_recent_pr_dump.py",
    "pr:refresh:all": "python3 knowledge/sources/past_prs/commands/fetch_recent_pr_dump.py --all-prs --fetch-jobs 32 --postmortem-mode pi --postmortem-jobs 32 --postmortem-scope all",
    "pr:refresh:dry": "python3 knowledge/sources/past_prs/commands/fetch_recent_pr_dump.py --dry-run",
    "pr:postmortems": "python3 knowledge/sources/past_prs/commands/build_pr_postmortems.py",
    "pr:sync": "python3 knowledge/sources/past_prs/commands/sync_repo_and_pr_library.py",
    "pr:sync:all": "python3 knowledge/sources/past_prs/commands/sync_repo_and_pr_library.py --all-prs --fetch-jobs 32 --postmortem-jobs 32"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "bun-types": "latest",
    "typescript": "latest"
  }
}
