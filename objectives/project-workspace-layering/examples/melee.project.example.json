{
  "id": "melee",
  "displayName": "Super Smash Bros. Melee",
  "kind": "doldecomp-melee",
  "repoRoot": "./checkout",
  "stateDir": "./state",
  "graphDb": "./graph/graph.sqlite",
  "processName": "melee-live",
  "baseRef": "origin/master",
  "validation": {
    "qaTarget": "build/GALE01",
    "reportPath": "build/GALE01/report.json",
    "reportChangesPath": "build/GALE01/report_changes.json",
    "objdiffPath": "objdiff.json"
  },
  "dashboard": {
    "candidateLimit": 80,
    "queueTargetSize": 24,
    "queueLowWatermark": 12,
    "candidateWindow": 80,
    "goalValue": 100
  },
  "pr": {
    "groupMode": "melee-subsystem",
