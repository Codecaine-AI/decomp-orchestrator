    "branchPrefix": "decomp",
    "maxFilesPerPr": 8
  },
  "knowledge": {
    "globalSources": [
      "past_prs",
      "decomp_standards",
      "resource_guides",
      "ssbm_data_sheet",
      "powerpc_docs",
      "external_mirrors",
      "reference_docs",
      "path_facts"
    ],
    "projectSources": [
      "code_graph",
      "tool_outputs"
    ]
  }
}
