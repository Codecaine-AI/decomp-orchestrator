_count":21,"license":null,"allow_forking":true,"is_template":false,"web_commit_signoff_required":false,"has_pull_requests":true,"pull_request_creation_policy":"all","topics":[],"visibility":"public","forks":136,"open_issues":21,"watchers":901,"default_branch":"master"}},"_links":{"self":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2411"},"html":{"href":"https://github.com/doldecomp/melee/pull/2411"},"issue":{"href":"https://api.github.com/repos/doldecomp/melee/issues/2411"},"comments":{"href":"https://api.github.com/repos/doldecomp/melee/issues/2411/comments"},"review_comments":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2411/comments"},"review_comment":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/comments{/number}"},"commits":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2411/commits"},"statuses":{"href":"https://api.github.com/repos/doldecomp/melee/statuses/6953651665460cc08baa56ebe92eb96d6417aac9"}},"author_association":"COLLABORATOR","auto_merge":{"enabled_by":{"login":"jellejurre","id":76777936,"node_id":"MDQ6VXNlcjc2Nzc3OTM2","avatar_url":"https://avatars.githubusercontent.com/u/76777936?v=4","gravatar_id":"","url":"https://api.github.com/users/jellejurre","html_url":"https://github.com/jellejurre","followers_url":"https://api.github.com/users/jellejurre/followers","following_url":"https://api.github.com/users/jellejurre/following{/other_user}","gists_url":"https://api.github.com/users/jellejurre/gists{/gist_id}","starred_url":"https://api.github.com/users/jellejurre/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/jellejurre/subscriptions","organizations_url":"https://api.github.com/users/jellejurre/orgs","repos_url":"https://api.github.com/users/jellejurre/repos","events_url":"https://api.github.com/users/jellejurre/events{/privacy}","received_events_url":"https://api.github.com/users/jellejurre/received_events","type":"User","user_view_type":"public","site_admin":false},"merge_method":"squash","commit_title":"Jj/gm 16 f1 (#2411)","commit_message":"* Match fn_8016F9A8 (100%)\n\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\n\n* Match fn_8016F740 (100%)\n\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\n\n* gm_16F1: Implement fn_8016FFD4 (93.8% match)\n\nRemaining diffs are register allocation/scheduling cosmetics\n(r24/r25/r26 swaps, lis prologue hoisting). Logic is 100% correct.\n\nAlso updated fn_8016FAD4 prototype to use int params (avoids\nunnecessary truncation at call sites).\n\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\n\n* Implement fn_8016F39C (97.66% match)\n\nRegister allocation differences only - all instructions match structurally.\nUpdates header prototype: HSD_Text**, void*, u8, u16, u8, u8 -> int\n\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\n\n* Implement fn_8016F548 (99.01% match)\n\nCombined forward+backward search. Register allocation diffs only.\nUpdates header prototype: void*, u16, u8, u8 -> int\n\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\n\n* Implement fn_80171BA4 (94.43% match)\n\nPlayer scoring/ranking function. Register allocation diffs (stmw r24 vs r23).\nCompiler CSE difference for score array base pointer.\n\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\n\n* fn_80171DC4: implement player winner/loser flag tracking (99.38% match)\n\nTwo-branch function: init branch sets winner (rank==0) and loser\n(rank==max) flags for active players, else branch clears stale flags.\nRemaining diffs are stack frame size (0x18 vs 0x10) and lbl_804D65B0\nregister allocation (r0 vs r7).\n\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\n\n* Implement fn_8016FAD4 (95.86% match)\n\nComplex decision function with score computation, ranking, and\nplayer evaluation. Remaining diffs are stack frame (+8 bytes),\nsdata2 relocations, mullw operand order (6 instances), and\n13 instructions of dead code that MWCC partially eliminated.\n\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\n\n* partway of the last func\n\n* Fix build issues\n\n* Cleanup\n\n* Fix regressions\n\n* Fix types\n\n* Fix more types\n\n* Almost fix fn_8016FFD4\n\n* Work my magic\n\n* Fix oopsie\n\n* Fix fn_8016F870\n\n---------\n\nCo-authored-by: sysop <sysop@decomp.local>\nCo-authored-by: Copilot <223556219+Copilot@users.noreply.github.com>\nCo-authored-by: jellejurre <git@jellejurre.dev>"},"assignee":null,"active_lock_reason":null,"merged":true,"mergeable":null,"rebaseable":null,"mergeable_state":"unknown","merged_by":{"login":"jellejurre","id":76777936,"node_id":"MDQ6VXNlcjc2Nzc3OTM2","avatar_url":"https://avatars.githubusercontent.com/u/76777936?v=4","gravatar_id":"","url":"https://api.github.com/users/jellejurre","html_url":"https://github.com/jellejurre","followers_url":"https://api.github.com/users/jellejurre/followers","following_url":"https://api.github.com/users/jellejurre/following{/other_user}","gists_url":"https://api.github.com/users/jellejurre/gists{/gist_id}","starred_url":"https://api.github.com/users/jellejurre/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/jellejurre/subscriptions","organizations_url":"https://api.github.com/users/jellejurre/orgs","repos_url":"https://api.github.com/users/jellejurre/repos","events_url":"https://api.github.com/users/jellejurre/events{/privacy}","received_events_url":"https://api.github.com/users/jellejurre/received_events","type":"User","user_view_type":"public","site_admin":false},"comments":1,"review_comments":0,"maintainer_can_modify":false,"commits":21,"additions":1247,"deletions":57,"changed_files":7}