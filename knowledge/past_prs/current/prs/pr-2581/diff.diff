-        new_y = min_ay;
-    }
-    dy = new_y - max_ay;
-    if (dy > 0.0) {
-        if (dy > 0.1) {
-            return false;
-        }
-        new_y = max_ay;
-    }
-    *int_x = a0x;
-    *int_y = new_y;
-    return true;
-}
