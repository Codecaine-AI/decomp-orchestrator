/repos/doldecomp/melee/comments{/number}","issue_comment_url":"https://api.github.com/repos/doldecomp/melee/issues/comments{/number}","contents_url":"https://api.github.com/repos/doldecomp/melee/contents/{+path}","compare_url":"https://api.github.com/repos/doldecomp/melee/compare/{base}...{head}","merges_url":"https://api.github.com/repos/doldecomp/melee/merges","archive_url":"https://api.github.com/repos/doldecomp/melee/{archive_format}{/ref}","downloads_url":"https://api.github.com/repos/doldecomp/melee/downloads","issues_url":"https://api.github.com/repos/doldecomp/melee/issues{/number}","pulls_url":"https://api.github.com/repos/doldecomp/melee/pulls{/number}","milestones_url":"https://api.github.com/repos/doldecomp/melee/milestones{/number}","notifications_url":"https://api.github.com/repos/doldecomp/melee/notifications{?since,all,participating}","labels_url":"https://api.github.com/repos/doldecomp/melee/labels{/name}","releases_url":"https://api.github.com/repos/doldecomp/melee/releases{/id}","deployments_url":"https://api.github.com/repos/doldecomp/melee/deployments","created_at":"2020-06-30T23:27:55Z","updated_at":"2026-06-01T22:58:14Z","pushed_at":"2026-06-01T22:58:08Z","git_url":"git://github.com/doldecomp/melee.git","ssh_url":"git@github.com:doldecomp/melee.git","clone_url":"https://github.com/doldecomp/melee.git","svn_url":"https://github.com/doldecomp/melee","homepage":null,"size":145408,"stargazers_count":901,"watchers_count":901,"language":"C","has_issues":true,"has_projects":true,"has_downloads":true,"has_wiki":true,"has_pages":true,"has_discussions":false,"forks_count":136,"mirror_url":null,"archived":false,"disabled":false,"open_issues_count":21,"license":null,"allow_forking":true,"is_template":false,"web_commit_signoff_required":false,"has_pull_requests":true,"pull_request_creation_policy":"all","topics":[],"visibility":"public","forks":136,"open_issues":21,"watchers":901,"default_branch":"master"}},"_links":{"self":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2515"},"html":{"href":"https://github.com/doldecomp/melee/pull/2515"},"issue":{"href":"https://api.github.com/repos/doldecomp/melee/issues/2515"},"comments":{"href":"https://api.github.com/repos/doldecomp/melee/issues/2515/comments"},"review_comments":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2515/comments"},"review_comment":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/comments{/number}"},"commits":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2515/commits"},"statuses":{"href":"https://api.github.com/repos/doldecomp/melee/statuses/dbf93fa9d9371944069f2be4342882138d76b3bd"}},"author_association":"CONTRIBUTOR","auto_merge":{"enabled_by":{"login":"ribbanya","id":5190964,"node_id":"MDQ6VXNlcjUxOTA5NjQ=","avatar_url":"https://avatars.githubusercontent.com/u/5190964?v=4","gravatar_id":"","url":"https://api.github.com/users/ribbanya","html_url":"https://github.com/ribbanya","followers_url":"https://api.github.com/users/ribbanya/followers","following_url":"https://api.github.com/users/ribbanya/following{/other_user}","gists_url":"https://api.github.com/users/ribbanya/gists{/gist_id}","starred_url":"https://api.github.com/users/ribbanya/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/ribbanya/subscriptions","organizations_url":"https://api.github.com/users/ribbanya/orgs","repos_url":"https://api.github.com/users/ribbanya/repos","events_url":"https://api.github.com/users/ribbanya/events{/privacy}","received_events_url":"https://api.github.com/users/ribbanya/received_events","type":"User","user_view_type":"public","site_admin":false},"merge_method":"squash","commit_title":"lb: improve lbcollision capsule-collision matching (#2515)","commit_message":"* lb: improve lbcollision capsule-collision matching\n\nlbColl_80006094 (capsule-vs-capsule 2D narrow-phase): 78.7% -> 91.4%\nlbColl_800067F8 (capsule-vs-capsule 2D contact solve): 78.7% -> 89.4%\nlbColl_80006E58 (3D segment/capsule narrow-phase + contact): 81.0% -> 95.4%\n\nNotable code changes:\n- Name the parameters of lbColl_80006E58 after their roles.\n- Drop the now-unused lbColl_JObjGetMtxPtr inline and its two\n  adjacent lbColl_804D37* assert strings.\n- Convert several float xx_x/_y/_z triplets into Vec3 xx where the\n  asm uses them as a unit (d1, d2 in lbColl_80005C44; d1 in the\n  parallel-axes branches of lbColl_80006E58).\n- Introduce a between(x, lo, hi) helper to fold a recurring\n  bounds-check pattern out of the closest-point solves.\n- Fold hit_param = (hit_param_candidate = ...) into an assignment\n  expression in the closest-points solve so the compiler keeps both\n  values live without redundant fmr.\n- Cache the constant 1.0 in a callee-save float to avoid reloading\n  it across several *_param = 1.0 branches in lbColl_80006E58.\n\nThree functions in this file (lbColl_80006094, lbColl_800067F8,\nlbColl_80006E58) still have residual float-register-allocation\nmismatches and are left unmatched at the percentages above.\n\n* ci: re-trigger checks after editorconfig network timeout\n\n* lb: restore lbColl_80005C44 locals to match expected stack layout\n\nReplacing the `float d2_x; float d2_y; float d2_z;` triplet with\n`Vec3 d2;` and moving `Vec3 d1;` ahead of `Vec3 sp38; Vec3 sp2C;`\nexpanded the local stack frame by 8 bytes (-0x48 -> -0x50). The\nextra 8 bytes don't change the visible code path but do shift every\nstack-relative offset, leaving lbColl_80005C44 at 99.99% (-1 byte).\n\nRestore the upstream declaration order and the three-float `d2`\nlocals. Body otherwise unchanged.\n\nlbColl_80005C44: 99.99% -> 100%.\n\n* lb: improve lbcollision capsule-collision matching\n\nlbColl_80006094 (capsule-vs-capsule 2D narrow-phase): 78.7% -> 91.4%\nlbColl_800067F8 (capsule-vs-capsule 2D contact solve): 78.7% -> 89.4%\nlbColl_80006E58 (3D segment/capsule narrow-phase + contact): 81.0% -> 95.4%\n\nNotable code changes:\n- Name the parameters of lbColl_80006E58 after their roles.\n- Drop the now-unused lbColl_JObjGetMtxPtr inline and its two\n  adjacent lbColl_804D37* assert strings.\n- Convert several float xx_x/_y/_z triplets into Vec3 xx where the\n  asm uses them as a unit (d1, d2 in lbColl_80005C44; d1 in the\n  parallel-axes branches of lbColl_80006E58).\n- Introduce a between(x, lo, hi) helper to fold a recurring\n  bounds-check pattern out of the closest-point solves.\n- Fold hit_param = (hit_param_candidate = ...) into an assignment\n  expression in the closest-points solve so the compiler keeps both\n  values live without redundant fmr.\n- Cache the constant 1.0 in a callee-save float to avoid reloading\n  it across several *_param = 1.0 branches in lbColl_80006E58.\n\nThree functions in this file (lbColl_80006094, lbColl_800067F8,\nlbColl_80006E58) still have residual float-register-allocation\nmismatches and are left unmatched at the percentages above.\n\n* Clean up `lbColl_80005C44`\n\n---------\n\nCo-authored-by: itsgrimetime <990274+itsgrimetime@users.noreply.github.com>\nCo-authored-by: Robin Avery <robin@ribbanya.dev>"},"assignee":null,"active_lock_reason":null,"merged":true,"mergeable":null,"rebaseable":null,"mergeable_state":"unknown","merged_by":{"login":"ribbanya","id":5190964,"node_id":"MDQ6VXNlcjUxOTA5NjQ=","avatar_url":"https://avatars.githubusercontent.com/u/5190964?v=4","gravatar_id":"","url":"https://api.github.com/users/ribbanya","html_url":"https://github.com/ribbanya","followers_url":"https://api.github.com/users/ribbanya/followers","following_url":"https://api.github.com/users/ribbanya/following{/other_user}","gists_url":"https://api.github.com/users/ribbanya/gists{/gist_id}","starred_url":"https://api.github.com/users/ribbanya/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/ribbanya/subscriptions","organizations_url":"https://api.github.com/users/ribbanya/orgs","repos_url":"https://api.github.com/users/ribbanya/repos","events_url":"https://api.github.com/users/ribbanya/events{/privacy}","received_events_url":"https://api.github.com/users/ribbanya/received_events","type":"User","user_view_type":"public","site_admin":false},"comments":4,"review_comments":0,"maintainer_can_modify":false,"commits":6,"additions":670,"deletions":621,"changed_files":1}