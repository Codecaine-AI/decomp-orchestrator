sabled":false,"open_issues_count":21,"license":null,"allow_forking":true,"is_template":false,"web_commit_signoff_required":false,"has_pull_requests":true,"pull_request_creation_policy":"all","topics":[],"visibility":"public","forks":136,"open_issues":21,"watchers":901,"default_branch":"master"}},"_links":{"self":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2532"},"html":{"href":"https://github.com/doldecomp/melee/pull/2532"},"issue":{"href":"https://api.github.com/repos/doldecomp/melee/issues/2532"},"comments":{"href":"https://api.github.com/repos/doldecomp/melee/issues/2532/comments"},"review_comments":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2532/comments"},"review_comment":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/comments{/number}"},"commits":{"href":"https://api.github.com/repos/doldecomp/melee/pulls/2532/commits"},"statuses":{"href":"https://api.github.com/repos/doldecomp/melee/statuses/d22a5a31b842ec10d80bd6da5cf24e0916d68764"}},"author_association":"COLLABORATOR","auto_merge":{"enabled_by":{"login":"jurrejelle","id":36511264,"node_id":"MDQ6VXNlcjM2NTExMjY0","avatar_url":"https://avatars.githubusercontent.com/u/36511264?v=4","gravatar_id":"","url":"https://api.github.com/users/jurrejelle","html_url":"https://github.com/jurrejelle","followers_url":"https://api.github.com/users/jurrejelle/followers","following_url":"https://api.github.com/users/jurrejelle/following{/other_user}","gists_url":"https://api.github.com/users/jurrejelle/gists{/gist_id}","starred_url":"https://api.github.com/users/jurrejelle/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/jurrejelle/subscriptions","organizations_url":"https://api.github.com/users/jurrejelle/orgs","repos_url":"https://api.github.com/users/jurrejelle/repos","events_url":"https://api.github.com/users/jurrejelle/events{/privacy}","received_events_url":"https://api.github.com/users/jurrejelle/received_events","type":"User","user_view_type":"public","site_admin":false},"merge_method":"squash","commit_title":"Jj/grbigblueroute 2 (#2532)","commit_message":"* Match grBigBlueRoute_8020BF38 (98%)\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* Match grBigBlueRoute_8020DAB4 (98%)\n\nPool __FILE__ into the file string literal so asserts reference the\nshared grBb_Route_803E61D4 pool, fixing the data-offset mismatch across\nthe unit's HSD_ASSERT calls.\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* Match grBigBlueRoute_8020BC68 (99%)\n\nUse the bigblueroute2 struct view so the jobj caches and translation\nvectors use displacement addressing instead of cached pointers.\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* Match grBigBlueRoute_8020C530 (100%)\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* Use float literals in grBigBlueRoute_8020BF38 to fix sdata2 pool order\n\nReferencing 30/4000 as extern symbols left them out of the unit's\n.sdata2 literal pool, shifting every later constant. Emitting them as\nliterals aligns the pool with the target and improves 8020DD64.\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* Match grBigBlueRoute_8020C85C (92%)\n\nFix the route-entry angle randomization to use 5.2359877/2.6179938\ninstead of 2.0/1.0, which also corrects the unit's sdata2 pool order.\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* Implement grBigBlueRoute_8020CD20 (86%)\n\nImplement the route state-machine update from scratch (was a stub):\n4-state per-entry animation, spline positioning, jobj transforms and\nproximity sound/camera triggers. Include trigf.h so atan2f returns f32.\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* Improve grBigBlueRoute_8020C85C to 92%\n\nExpress the early-out as !(x108 < limit) so the float compare emits bge\ninstead of cror+beq, matching the target.\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* Improve grBigBlueRoute_8020CD20 to 89%\n\nReload the RouteEntry base per field access (via macro) to match the\ntarget's addressing instead of caching the pointer in a saved register.\n\nCo-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\n\n* grbigblueroute: inline float consts as literals (drop extern-const trick)\n\n* grbigblueroute: include lb/lbshadow.h (fix implicit decl of lbShadow_8000E9F0)\n\n* Fix pointer math\n\n* match grBigBlueRoute_8020DAB4\n\n* improvement on grBigBlueRoute_8020C85C\n\n* Match grBigBlueRoute_8020BF38\n\n* Fix asserts\n\n---------\n\nCo-authored-by: Claude Opus 4.7 (1M context) <noreply@anthropic.com>\nCo-authored-by: jellejurre <git@jellejurre.dev>\nCo-authored-by: JelleJurre <76777936+jellejurre@users.noreply.github.com>"},"assignee":null,"active_lock_reason":null,"merged":true,"mergeable":null,"rebaseable":null,"mergeable_state":"unknown","merged_by":{"login":"jurrejelle","id":36511264,"node_id":"MDQ6VXNlcjM2NTExMjY0","avatar_url":"https://avatars.githubusercontent.com/u/36511264?v=4","gravatar_id":"","url":"https://api.github.com/users/jurrejelle","html_url":"https://github.com/jurrejelle","followers_url":"https://api.github.com/users/jurrejelle/followers","following_url":"https://api.github.com/users/jurrejelle/following{/other_user}","gists_url":"https://api.github.com/users/jurrejelle/gists{/gist_id}","starred_url":"https://api.github.com/users/jurrejelle/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/jurrejelle/subscriptions","organizations_url":"https://api.github.com/users/jurrejelle/orgs","repos_url":"https://api.github.com/users/jurrejelle/repos","events_url":"https://api.github.com/users/jurrejelle/events{/privacy}","received_events_url":"https://api.github.com/users/jurrejelle/received_events","type":"User","user_view_type":"public","site_admin":false},"comments":1,"review_comments":0,"maintainer_can_modify":false,"commits":18,"additions":457,"deletions":131,"changed_files":3}