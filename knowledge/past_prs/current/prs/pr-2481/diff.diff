+    /* 0x44 */ void* x44;     /* image ptr for tex1 */
+    /* 0x48 */ GXTexObj tex2; /* 0x48-0x68 (size 0x20) */
+    /* 0x68 */ void* x68;     /* image ptr for tex2 */
+    /* 0x6C */ u16 x6C;       /* width */
+    /* 0x6E */ u16 x6E;       /* height */
+    /* 0x70 */ s32 x70;
+    /* 0x74 */ u16 x74;
+    /* 0x76 */ u16 x76;
