08F0\n\n---------\n\nCo-authored-by: Claude Opus 4.6 <noreply@anthropic.com>\nCo-authored-by: Jurre Groenendijk <jurre@jilles.com>"},"assignee":null,"active_lock_reason":null,"merged":true,"mergeable":null,"rebaseable":null,"mergeable_state":"unknown","merged_by":{"login":"jurrejelle","id":36511264,"node_id":"MDQ6VXNlcjM2NTExMjY0","avatar_url":"https://avatars.githubusercontent.com/u/36511264?v=4","gravatar_id":"","url":"https://api.github.com/users/jurrejelle","html_url":"https://github.com/jurrejelle","followers_url":"https://api.github.com/users/jurrejelle/followers","following_url":"https://api.github.com/users/jurrejelle/following{/other_user}","gists_url":"https://api.github.com/users/jurrejelle/gists{/gist_id}","starred_url":"https://api.github.com/users/jurrejelle/starred{/owner}{/repo}","subscriptions_url":"https://api.github.com/users/jurrejelle/subscriptions","organizations_url":"https://api.github.com/users/jurrejelle/orgs","repos_url":"https://api.github.com/users/jurrejelle/repos","events_url":"https://api.github.com/users/jurrejelle/events{/privacy}","received_events_url":"https://api.github.com/users/jurrejelle/received_events","type":"User","user_view_type":"public","site_admin":false},"comments":1,"review_comments":0,"maintainer_can_modify":false,"commits":8,"additions":231,"deletions":12,"changed_files":10}