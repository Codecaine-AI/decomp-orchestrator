+        goto t1;
+    }
+    if (!(coll->env_flags & Collide_RightWallHug)) {
+        goto t2;
+    }
+t1:
+    fp->cur_pos.x = -(fp->x68C_transNPos.z * -fp->facing_dir -
+                      (fp->cur_pos.x + offset->x));
+    goto end;
+t2:
+    fp->cur_pos.y = fp->x68C_transNPos.y + (fp->cur_pos.y + offset->y);
+end:
