+    ftCo_80090574(gobj);
+    fp->dmg.x18A8 = mag;
+    ftCommon_8007EBAC(fp, 7, 0);
+    ftColl_8007B760(gobj, p_ftCommonData->x1B8);
+    PAD_STACK(4);
+}
