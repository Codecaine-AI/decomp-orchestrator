+        ftData* ftData = fp->ft_data;
+        ftCrazyHand_DatAttrs* da = ftData->ext_attr;
+
+        {
+            Vec3 pos;
+            ftBossLib_8015C208(gobj, &pos);
+            pos.x += da->x5C;
+            pos.y += da->x60;
+            pos.z = 0;
+
+            {
+                Vec3 vel;
+                lbVector_Diff(&pos, &fp->cur_pos, &vel);
+                {
+                    float len = my_lbVector_Len(&vel);
+                    if (len < da->x14) {
+                        fp->self_vel.x = vel.x;
+                        fp->self_vel.y = vel.y;
+                    } else {
+                        lbVector_Normalize(&vel);
+                        {
+                            float speed = len * da->x10;
+                            vel.x *= speed;
+                            vel.y *= speed;
+                            vel.z *= speed;
+                        }
+                        fp->self_vel.x = vel.x;
+                        fp->self_vel.y = vel.y;
+                    }
+                }
+            }
+        }
